<Window x:Class="VAdapter.App.Views.HelpWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="V-Adapter — ヘルプ" Height="520" Width="560"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="16">
        <StackPanel DockPanel.Dock="Top" Orientation="Horizontal" Margin="0,0,0,14">
            <Path Width="22" Height="22" Stretch="Uniform" Data="{StaticResource I.Mic}"
                  Stroke="{StaticResource B.Primary}" StrokeThickness="1.7"
                  StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round"/>
            <TextBlock Text="V-Adapter" FontSize="18" FontWeight="SemiBold" VerticalAlignment="Center" Margin="9,0,0,0"/>
            <Border VerticalAlignment="Center" Margin="8,2,0,0" Background="{StaticResource B.Accent}"
                    CornerRadius="999" Padding="7,1">
                <TextBlock Text="v0.0.1 α" FontSize="11" FontWeight="SemiBold" Foreground="{StaticResource B.PrimaryDark}"/>
            </Border>
        </StackPanel>

        <Button DockPanel.Dock="Bottom" Style="{StaticResource PrimaryButton}"
                HorizontalAlignment="Right" Width="100" Margin="0,14,0,0" IsCancel="True">
            <TextBlock Text="閉じる" Foreground="White"/>
        </Button>

        <ScrollViewer VerticalScrollBarVisibility="Auto">
            <StackPanel>
                <!-- 使い方 -->
                <Expander IsExpanded="True" Margin="0,0,0,10" Foreground="{StaticResource B.TextPrimary}">
                    <Expander.Header>
                        <TextBlock Text="使い方" FontSize="14" FontWeight="SemiBold"/>
                    </Expander.Header>
                    <Border Background="{StaticResource B.HoverBg}" BorderBrush="{StaticResource B.Border}"
                            BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,8,0,0">
                        <StackPanel>
                            <TextBlock TextWrapping="Wrap" LineHeight="22" Foreground="{StaticResource B.TextSecondary}">
                                <Run FontWeight="SemiBold" Foreground="{StaticResource B.TextPrimary}">1. 対象アプリを登録</Run><LineBreak/>
                                「対象アプリ管理」を開き、合成音声ソフトを登録します。「実行中ウィンドウから取得」で起動中のアプリを選ぶと簡単です。座標モード（相対／絶対）を選べます。<LineBreak/><LineBreak/>
                                <Run FontWeight="SemiBold" Foreground="{StaticResource B.TextPrimary}">2. マクロを実行</Run><LineBreak/>
                                一覧でマクロを選んで「実行」、または設定したショートカットキーで起動します。標準マクロ：音声の再生（Ctrl+Space）／音声の保存（Ctrl+E）。<LineBreak/><LineBreak/>
                                <Run FontWeight="SemiBold" Foreground="{StaticResource B.TextPrimary}">3. 送信先を固定（任意）</Run><LineBreak/>
                                複数の合成音声ソフトを同時起動しているときは、右の「送信先」で送信先アプリを固定できます。未選択時は前面のアプリを自動判定します。<LineBreak/><LineBreak/>
                                <Run FontWeight="SemiBold" Foreground="{StaticResource B.TextPrimary}">4. マクロを編集</Run><LineBreak/>
                                「操作」→「編集」でマクロを開き、対象アプリごとのスクリプト（命令列）を作成します。命令：待機／クリック（基準位置でサイズ追従）／キー送信／ウィンドウ・ダイアログ・テキスト・アプリ切替の各待ち／操作対象の切り替え。<LineBreak/><LineBreak/>
                                <Run FontWeight="SemiBold" Foreground="{StaticResource B.TextPrimary}">5. テンプレートの活用</Run><LineBreak/>
                                A.I.VOICE2／CeVIO AI／VOICEPEAK／VoiSona Talk／VOICEVOX は対象アプリのテンプレートとして同梱しています。お使いの環境で「対象アプリ管理」から登録するとマクロが利用できます。
                            </TextBlock>
                            <TextBlock Margin="0,10,0,0" FontSize="11" Foreground="{StaticResource B.TextMuted}" TextWrapping="Wrap"
                                       Text="補足: 日本語OCR（テキスト表示待ち）には Windows の OCR 言語機能（日本語）が必要です。管理者権限で動くアプリを操作する場合は本アプリも管理者として実行してください。"/>
                        </StackPanel>
                    </Border>
                </Expander>

                <!-- 更新履歴 -->
                <Expander IsExpanded="False" Foreground="{StaticResource B.TextPrimary}">
                    <Expander.Header>
                        <TextBlock Text="更新履歴" FontSize="14" FontWeight="SemiBold"/>
                    </Expander.Header>
                    <Border Background="{StaticResource B.HoverBg}" BorderBrush="{StaticResource B.Border}"
                            BorderThickness="1" CornerRadius="6" Padding="14" Margin="0,8,0,0">
                        <TextBlock TextWrapping="Wrap" LineHeight="22" Foreground="{StaticResource B.TextSecondary}">
                            <Run FontWeight="SemiBold" Foreground="{StaticResource B.TextPrimary}">v0.0.1 (α) — 初回リリース</Run><LineBreak/>
                            ・標準マクロ（音声の再生 / 音声の保存）を同梱<LineBreak/>
                            ・1マクロに対象アプリごとのスクリプトを保持／前面アプリ自動判定・送信先固定<LineBreak/>
                            ・命令：待機・クリック（アンカー基準でサイズ追従）・キー送信（スキャンコード送信）・ウィンドウ／ダイアログ／テキスト（OCR）／アプリ切替の各待ち・操作対象の切り替え<LineBreak/>
                            ・対象アプリ検出をプロセス名優先＋クラス正規化（GUID/JUCE/WinForms 揺れに対応）で安定化<LineBreak/>
                            ・座標・領域・ウィンドウクラスをクリック取得、ドラッグ範囲選択<LineBreak/>
                            ・マクロのインポート／エクスポート（.vamacro）<LineBreak/>
                            ・デザインシステムに沿った UI へ刷新／最前面ピン留め
                        </TextBlock>
                    </Border>
                </Expander>
            </StackPanel>
        </ScrollViewer>
    </DockPanel>
</Window>
