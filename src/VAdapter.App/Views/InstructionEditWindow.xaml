<Window x:Class="VAdapter.App.Views.InstructionEditWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="命令の編集" Height="Auto" Width="460" SizeToContent="Height"
        WindowStartupLocation="CenterOwner" ResizeMode="NoResize">
    <DockPanel Margin="14">
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,14,0,0">
            <Button Content="OK" Width="90" Margin="0,0,8,0" IsDefault="True" Click="OnOk"/>
            <Button Content="キャンセル" Width="90" IsCancel="True"/>
        </StackPanel>

        <StackPanel>
            <TextBlock x:Name="TitleText" FontWeight="Bold" FontSize="14" Margin="0,0,0,10"/>

            <!-- 待機 -->
            <StackPanel x:Name="WaitPanel" Visibility="Collapsed">
                <TextBlock Text="待機時間 (ミリ秒)" Margin="0,0,0,2"/>
                <TextBox x:Name="WaitMsBox" Width="160" HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- クリック -->
            <StackPanel x:Name="ClickPanel" Visibility="Collapsed">
                <TextBlock Text="座標モード" Margin="0,0,0,2"/>
                <ComboBox x:Name="ClickModeCombo" Width="240" HorizontalAlignment="Left" Margin="0,0,0,10">
                    <ComboBoxItem Content="既定（対象アプリ設定に従う）" Tag="default"/>
                    <ComboBoxItem Content="相対（ウィンドウ左上基準）" Tag="relative"/>
                    <ComboBoxItem Content="絶対（ディスプレイ基準）" Tag="absolute"/>
                </ComboBox>

                <StackPanel x:Name="ClickAnchorRow" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="基準位置" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="ClickAnchorCombo" Width="200">
                        <ComboBoxItem Content="左上" Tag="TopLeft"/>
                        <ComboBoxItem Content="右上" Tag="TopRight"/>
                        <ComboBoxItem Content="左下" Tag="BottomLeft"/>
                        <ComboBoxItem Content="右下" Tag="BottomRight"/>
                        <ComboBoxItem Content="中央" Tag="Center"/>
                    </ComboBox>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="X" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="ClickXBox" Width="80" Margin="0,0,16,0"/>
                    <TextBlock Text="Y" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <TextBox x:Name="ClickYBox" Width="80"/>
                </StackPanel>

                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="ボタン" VerticalAlignment="Center" Margin="0,0,6,0"/>
                    <ComboBox x:Name="ClickButtonCombo" Width="120">
                        <ComboBoxItem Content="左" Tag="Left"/>
                        <ComboBoxItem Content="右" Tag="Right"/>
                        <ComboBoxItem Content="中" Tag="Middle"/>
                    </ComboBox>
                </StackPanel>

                <Button x:Name="CaptureCoordButton" Content="座標を取得（クリックで指定）…"
                        Width="240" HorizontalAlignment="Left" Click="OnCaptureCoordinate"/>
                <TextBlock x:Name="CaptureHint" Foreground="Gray" TextWrapping="Wrap" Margin="0,6,0,0"
                           Text="ボタンを押すと本アプリが一時的に最小化されます。対象ウィンドウ上の目的の位置をクリックしてください。相対モードでは基準位置からのオフセットとして保存され、ウィンドウサイズ変化に追従します。"/>
            </StackPanel>

            <!-- キー送信 -->
            <StackPanel x:Name="SendKeysPanel" Visibility="Collapsed">
                <TextBlock Text="送信するキー組み合わせ" Margin="0,0,0,2"/>
                <StackPanel Orientation="Horizontal">
                    <TextBox x:Name="KeyBox" Width="260" IsReadOnly="True" Focusable="True"
                             PreviewKeyDown="OnKeyCapture" Text="(クリックしてキーを押す)"/>
                    <Button Content="クリア" Width="70" Margin="8,0,0,0" Click="OnClearKey"/>
                </StackPanel>
            </StackPanel>

            <!-- ウィンドウ表示待ち -->
            <StackPanel x:Name="WaitWindowPanel" Visibility="Collapsed">
                <TextBlock Text="タイムアウト (ミリ秒)" Margin="0,0,0,2"/>
                <TextBox x:Name="WaitWindowMsBox" Width="160" HorizontalAlignment="Left"/>
                <TextBlock Foreground="Gray" TextWrapping="Wrap" Margin="0,6,0,0"
                           Text="対象アプリのウィンドウが見つかるまで待機します（対象アプリの割当が必要）。"/>
            </StackPanel>

            <!-- アプリ切替待ち -->
            <StackPanel x:Name="WaitActivationPanel" Visibility="Collapsed">
                <TextBlock Text="タイムアウト (ミリ秒)" Margin="0,0,0,2"/>
                <TextBox x:Name="WaitActivationMsBox" Width="160" HorizontalAlignment="Left"/>
                <TextBlock Foreground="Gray" TextWrapping="Wrap" Margin="0,6,0,0"
                           Text="対象アプリが前面（アクティブ）になるまで待機します。スクリプト先頭での使用を推奨（対象アプリの割当が必要）。"/>
            </StackPanel>

            <!-- ダイアログ表示待ち -->
            <StackPanel x:Name="WaitDialogPanel" Visibility="Collapsed">
                <TextBlock Text="ダイアログのタイトル（部分一致・任意）" Margin="0,0,0,2"/>
                <TextBox x:Name="DialogTitleBox" Margin="0,0,0,10"/>
                <TextBlock Text="ダイアログのウィンドウクラス" Margin="0,0,0,2"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,8">
                    <TextBox x:Name="DialogClassBox" Width="200"/>
                    <Button Content="クリックで取得…" Width="120" Margin="8,0,0,0" Click="OnCaptureDialogClass"/>
                </StackPanel>
                <CheckBox x:Name="DialogForegroundCheck" Content="検出したら前面に表示する" Margin="0,0,0,8"/>
                <TextBlock Text="タイムアウト (ミリ秒)" Margin="0,0,0,2"/>
                <TextBox x:Name="WaitDialogMsBox" Width="160" HorizontalAlignment="Left"/>
                <TextBlock Foreground="Gray" TextWrapping="Wrap" Margin="0,6,0,0"
                           Text="Windows 標準ダイアログ（名前を付けて保存 等）は枠クラスが #32770 で固定です。対象アプリと同一プロセスのダイアログを検出するため、ウィンドウサイズや環境に依存しません。タイトル（例: 名前を付けて保存）で種類を絞れます。"/>
            </StackPanel>

            <!-- 操作対象の切り替え -->
            <StackPanel x:Name="SwitchTargetPanel" Visibility="Collapsed">
                <TextBlock Text="切替先" Margin="0,0,0,2"/>
                <ComboBox x:Name="SwitchTargetCombo" Width="240" HorizontalAlignment="Left" Margin="0,0,0,10"
                          SelectionChanged="OnSwitchTargetChanged">
                    <ComboBoxItem Content="ダイアログ" Tag="Dialog"/>
                    <ComboBoxItem Content="対象アプリ本体" Tag="AppWindow"/>
                </ComboBox>

                <StackPanel x:Name="SwitchDialogOptions">
                    <TextBlock Text="ダイアログのタイトル（部分一致・任意）" Margin="0,0,0,2"/>
                    <TextBox x:Name="SwitchTitleBox" Margin="0,0,0,10"/>
                    <TextBlock Text="ダイアログのウィンドウクラス" Margin="0,0,0,2"/>
                    <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                        <TextBox x:Name="SwitchClassBox" Width="200"/>
                        <Button Content="クリックで取得…" Width="120" Margin="8,0,0,0" Click="OnCaptureSwitchClass"/>
                    </StackPanel>
                    <TextBlock Text="検出タイムアウト (ミリ秒)" Margin="0,0,0,2"/>
                    <TextBox x:Name="SwitchMsBox" Width="160" HorizontalAlignment="Left"/>
                </StackPanel>

                <TextBlock Foreground="Gray" TextWrapping="Wrap" Margin="0,8,0,0"
                           Text="切替後の「キー送信」「絶対クリック」がこの対象（ダイアログ等）へ送られます。保存ダイアログで Enter やボタン押下を行う場合に使用します。相対クリックは対象アプリ本体が基準のままです。"/>
            </StackPanel>

            <!-- テキスト表示待ち -->
            <StackPanel x:Name="WaitTextPanel" Visibility="Collapsed">
                <TextBlock Text="検出するテキスト（部分一致）" Margin="0,0,0,2"/>
                <TextBox x:Name="WaitTextBox" Margin="0,0,0,10"/>

                <CheckBox x:Name="WholeWindowCheck" Content="ウィンドウ全体を対象にする"
                          Checked="OnWholeWindowToggled" Unchecked="OnWholeWindowToggled" Margin="0,0,0,8"/>

                <Button x:Name="DragRegionButton" Content="領域をドラッグで指定…" Width="200"
                        HorizontalAlignment="Left" Margin="0,0,0,8" Click="OnDragRegion"/>

                <StackPanel x:Name="RegionPanel" Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBlock Text="X" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="RegionXBox" Width="60" Margin="0,0,10,0"/>
                    <TextBlock Text="Y" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="RegionYBox" Width="60" Margin="0,0,10,0"/>
                    <TextBlock Text="幅" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="RegionWBox" Width="60" Margin="0,0,10,0"/>
                    <TextBlock Text="高" VerticalAlignment="Center" Margin="0,0,4,0"/>
                    <TextBox x:Name="RegionHBox" Width="60"/>
                </StackPanel>

                <TextBlock Text="タイムアウト (ミリ秒)" Margin="0,0,0,2"/>
                <TextBox x:Name="WaitTextMsBox" Width="160" HorizontalAlignment="Left"/>
            </StackPanel>

            <!-- 対象アプリの起動 -->
            <StackPanel x:Name="LaunchPanel" Visibility="Collapsed">
                <TextBlock Text="起動する実行ファイル（空欄で対象アプリの登録 exe を使用）" Margin="0,0,0,2"/>
                <StackPanel Orientation="Horizontal" Margin="0,0,0,10">
                    <TextBox x:Name="LaunchPathBox" Width="300"/>
                    <Button Content="参照…" Width="80" Margin="8,0,0,0" Click="OnBrowseLaunchExe"/>
                </StackPanel>
                <CheckBox x:Name="LaunchSkipRunningCheck" Content="既に起動している場合はスキップする" Margin="0,0,0,8"/>
                <TextBlock Foreground="Gray" TextWrapping="Wrap" Margin="0,4,0,0"
                           Text="空欄のときは、このスクリプトの対象アプリに登録された実行ファイルを起動します。特定の exe を起動する場合は「参照」で指定してください。起動に失敗した場合はマクロ実行が失敗としてログに表示されます。"/>
            </StackPanel>
        </StackPanel>
    </DockPanel>
</Window>
