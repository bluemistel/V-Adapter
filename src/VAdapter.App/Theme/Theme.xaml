<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:sys="clr-namespace:System;assembly=mscorlib"
    xmlns:conv="clr-namespace:VAdapter.App.Converters">

    <!-- ════════ デザイントークン: 色 ════════ -->
    <Color x:Key="C.AppBg">#FFF1F2F5</Color>
    <SolidColorBrush x:Key="B.AppBg" Color="#FFF1F2F5"/>
    <SolidColorBrush x:Key="B.Surface" Color="#FFFFFFFF"/>
    <SolidColorBrush x:Key="B.Border" Color="#FFE2E5EC"/>
    <SolidColorBrush x:Key="B.BorderLight" Color="#FFF1F2F5"/>
    <SolidColorBrush x:Key="B.Primary" Color="#FF3F6FB7"/>
    <SolidColorBrush x:Key="B.PrimaryHover" Color="#FF345D9C"/>
    <SolidColorBrush x:Key="B.PrimaryDark" Color="#FF284A7E"/>
    <SolidColorBrush x:Key="B.Accent" Color="#FFE9F0F9"/>
    <SolidColorBrush x:Key="B.AccentHover" Color="#FFCFDDF0"/>
    <SolidColorBrush x:Key="B.TextPrimary" Color="#FF2A303B"/>
    <SolidColorBrush x:Key="B.TextSecondary" Color="#FF4A5260"/>
    <SolidColorBrush x:Key="B.TextTertiary" Color="#FF6B7382"/>
    <SolidColorBrush x:Key="B.TextMuted" Color="#FF9099A8"/>
    <SolidColorBrush x:Key="B.HoverBg" Color="#FFF6F7FA"/>
    <SolidColorBrush x:Key="B.Danger" Color="#FFD26060"/>
    <SolidColorBrush x:Key="B.DangerHover" Color="#FFFAE5E5"/>
    <SolidColorBrush x:Key="B.CheckUnchecked" Color="#FFC8CDD7"/>
    <SolidColorBrush x:Key="B.ScrollThumb" Color="#FFC8CDD7"/>

    <FontFamily x:Key="F.App">Yu Gothic UI, Segoe UI, Meiryo UI</FontFamily>
    <FontFamily x:Key="F.Mono">Consolas, Cascadia Mono, monospace</FontFamily>

    <conv:KindBadgeConverter x:Key="KindBadge"/>
    <BooleanToVisibilityConverter x:Key="BoolToVis"/>

    <!-- ════════ アイコン Geometry ════════ -->
    <Geometry x:Key="I.Mic">M12,2 A3,3 0 0 1 15,5 L15,10 A3,3 0 0 1 9,10 L9,5 A3,3 0 0 1 12,2 Z M5,10 A7,7 0 0 0 19,10 M12,17 L12,21 M8,21 L16,21</Geometry>
    <Geometry x:Key="I.Pin">M12,17 L12,22 M9,3 L15,3 L14,10 L17,13 L7,13 L10,10 Z</Geometry>
    <Geometry x:Key="I.Grid">M3,3 L10,3 L10,10 L3,10 Z M14,3 L21,3 L21,10 L14,10 Z M3,14 L10,14 L10,21 L3,21 Z M14,14 L21,14 L21,21 L14,21 Z</Geometry>
    <Geometry x:Key="I.Play">M8,5 L8,19 L19,12 Z</Geometry>
    <Geometry x:Key="I.Plus">M12,5 L12,19 M5,12 L19,12</Geometry>
    <Geometry x:Key="I.Pencil">M12,20 L21,20 M16.5,3.5 A2.1,2.1 0 0 1 19.5,6.5 L7,19 L3,20 L4,16 Z</Geometry>
    <Geometry x:Key="I.Copy">M9,9 L20,9 L20,20 L9,20 Z M5,15 L5,5 A2,2 0 0 1 7,3 L17,3</Geometry>
    <Geometry x:Key="I.Trash">M3,6 L21,6 M19,6 L18,20 A2,2 0 0 1 16,22 L8,22 A2,2 0 0 1 6,20 L5,6 M10,11 L10,17 M14,11 L14,17</Geometry>
    <Geometry x:Key="I.Import">M21,15 L21,19 A2,2 0 0 1 19,21 L5,21 A2,2 0 0 1 3,19 L3,15 M7,10 L12,15 L17,10 M12,15 L12,3</Geometry>
    <Geometry x:Key="I.Export">M21,15 L21,19 A2,2 0 0 1 19,21 L5,21 A2,2 0 0 1 3,19 L3,15 M17,8 L12,3 L7,8 M12,3 L12,15</Geometry>
    <Geometry x:Key="I.ChevDown">M6,9 L12,15 L18,9</Geometry>
    <Geometry x:Key="I.ChevRight">M9,6 L15,12 L9,18</Geometry>
    <Geometry x:Key="I.Check">M20,6 L9,17 L4,12</Geometry>
    <Geometry x:Key="I.Help">M12,2 A10,10 0 1 1 11.99,2 Z M9.1,9 A3,3 0 0 1 14.9,10 C14.9,12 12,12.5 12,14 M12,17.5 L12,17.6</Geometry>
    <Geometry x:Key="I.Power">M12,3 L12,12 M7.8,6.4 A7,7 0 1 0 16.2,6.4</Geometry>

    <!-- ════════ ベース: Window / TextBlock ════════ -->
    <Style TargetType="{x:Type Window}">
        <Setter Property="Background" Value="{StaticResource B.AppBg}"/>
        <Setter Property="FontFamily" Value="{StaticResource F.App}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Foreground" Value="{StaticResource B.TextPrimary}"/>
        <Setter Property="TextOptions.TextFormattingMode" Value="Display"/>
        <Setter Property="UseLayoutRounding" Value="True"/>
    </Style>

    <!-- ════════ ボタン（既定 = セカンダリ白）════════ -->
    <Style TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="{StaticResource B.TextPrimary}"/>
        <Setter Property="Background" Value="{StaticResource B.Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource B.Border}"/>
        <Setter Property="FontFamily" Value="{StaticResource F.App}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="14,7"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="SnapsToDevicePixels" Value="True"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"
                                          RecognizesAccessKey="True"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.HoverBg}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- プライマリ（青） -->
    <Style x:Key="PrimaryButton" TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="White"/>
        <Setter Property="Background" Value="{StaticResource B.Primary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="SemiBold"/>
        <Setter Property="Padding" Value="15,7"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6"
                            Padding="{TemplateBinding Padding}" SnapsToDevicePixels="True">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.PrimaryHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 危険（削除） -->
    <Style x:Key="DangerButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Foreground" Value="{StaticResource B.Danger}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.DangerHover}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.5"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ゴースト（枠なし・ホバーで淡色） -->
    <Style x:Key="GhostButton" TargetType="{x:Type Button}">
        <Setter Property="Foreground" Value="{StaticResource B.TextSecondary}"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Padding" Value="11,7"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Button}">
                    <Border x:Name="bd" Background="{TemplateBinding Background}" CornerRadius="6"
                            Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.BorderLight}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- 小型アウトライン（操作行） -->
    <Style x:Key="SmallButton" TargetType="{x:Type Button}" BasedOn="{StaticResource {x:Type Button}}">
        <Setter Property="Foreground" Value="{StaticResource B.TextSecondary}"/>
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Padding" Value="10,4"/>
    </Style>

    <Style x:Key="SmallDangerButton" TargetType="{x:Type Button}" BasedOn="{StaticResource DangerButton}">
        <Setter Property="FontSize" Value="11"/>
        <Setter Property="FontWeight" Value="Normal"/>
        <Setter Property="Padding" Value="10,4"/>
    </Style>

    <!-- ════════ ToggleButton: ピン留め（アイコン）════════ -->
    <Style x:Key="PinToggle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Foreground" Value="{StaticResource B.TextTertiary}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="6"
                            BorderBrush="{StaticResource B.Border}" BorderThickness="1">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.HoverBg}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.Accent}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource B.Primary}"/>
                            <Setter Property="Foreground" Value="{StaticResource B.Primary}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════ ToggleButton: 展開（操作・ログ）════════ -->
    <Style x:Key="ExpanderToggle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Foreground" Value="{StaticResource B.TextSecondary}"/>
        <Setter Property="Background" Value="{StaticResource B.Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource B.Border}"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="10,0"/>
        <Setter Property="Height" Value="30"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Left" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.HoverBg}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ゴースト展開（操作） -->
    <Style x:Key="GhostToggle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Foreground" Value="{StaticResource B.TextSecondary}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Padding" Value="11,0"/>
        <Setter Property="Height" Value="34"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="bd" Background="Transparent" CornerRadius="6" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.BorderLight}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.BorderLight}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════ ToggleButton: 送信先ピル ════════ -->
    <Style x:Key="TargetPillToggle" TargetType="{x:Type ToggleButton}">
        <Setter Property="Height" Value="32"/>
        <Setter Property="Margin" Value="0,0,0,4"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="HorizontalContentAlignment" Value="Left"/>
        <Setter Property="FontSize" Value="12"/>
        <Setter Property="FontWeight" Value="Medium"/>
        <Setter Property="Foreground" Value="{StaticResource B.TextPrimary}"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ToggleButton}">
                    <Border x:Name="bd" Background="{StaticResource B.Surface}"
                            BorderBrush="{StaticResource B.Border}" BorderThickness="1"
                            CornerRadius="6" Padding="10,0">
                        <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                            <Path x:Name="chk" Width="13" Height="13" Margin="0,0,7,0" Stretch="Uniform"
                                  Data="{StaticResource I.Check}" Stroke="{TemplateBinding Foreground}"
                                  StrokeThickness="3" StrokeStartLineCap="Round" StrokeEndLineCap="Round"
                                  StrokeLineJoin="Round" Opacity="0"/>
                            <TextBlock x:Name="txt" Text="{TemplateBinding Content}" VerticalAlignment="Center"
                                       Foreground="{StaticResource B.TextPrimary}" TextTrimming="CharacterEllipsis"/>
                        </StackPanel>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.HoverBg}"/>
                        </Trigger>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.Primary}"/>
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource B.Primary}"/>
                            <Setter Property="Foreground" Value="White"/>
                            <Setter TargetName="txt" Property="Foreground" Value="White"/>
                            <Setter TargetName="chk" Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════ マクロ行のチェックボックス ════════ -->
    <Style x:Key="ListCheckBox" TargetType="{x:Type CheckBox}">
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type CheckBox}">
                    <Border x:Name="box" Width="17" Height="17" CornerRadius="4"
                            Background="{StaticResource B.Surface}" BorderBrush="{StaticResource B.CheckUnchecked}"
                            BorderThickness="1.5" SnapsToDevicePixels="True">
                        <Path x:Name="tick" Width="11" Height="11" Stretch="Uniform"
                              Data="{StaticResource I.Check}" Stroke="White" StrokeThickness="3"
                              StrokeStartLineCap="Round" StrokeEndLineCap="Round" StrokeLineJoin="Round" Opacity="0"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsChecked" Value="True">
                            <Setter TargetName="box" Property="Background" Value="{StaticResource B.Primary}"/>
                            <Setter TargetName="box" Property="BorderBrush" Value="{StaticResource B.Primary}"/>
                            <Setter TargetName="tick" Property="Opacity" Value="1"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════ TextBox ════════ -->
    <Style TargetType="{x:Type TextBox}">
        <Setter Property="Foreground" Value="{StaticResource B.TextPrimary}"/>
        <Setter Property="Background" Value="{StaticResource B.Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource B.Border}"/>
        <Setter Property="FontFamily" Value="{StaticResource F.App}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="CaretBrush" Value="{StaticResource B.TextPrimary}"/>
        <Setter Property="Padding" Value="7,5"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type TextBox}">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{TemplateBinding BorderBrush}" BorderThickness="1" CornerRadius="6">
                        <ScrollViewer x:Name="PART_ContentHost" Margin="{TemplateBinding Padding}"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsKeyboardFocused" Value="True">
                            <Setter TargetName="bd" Property="BorderBrush" Value="{StaticResource B.Primary}"/>
                        </Trigger>
                        <Trigger Property="IsEnabled" Value="False">
                            <Setter Property="Opacity" Value="0.6"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════ ComboBox（軽い配色調整）════════ -->
    <Style TargetType="{x:Type ComboBox}">
        <Setter Property="Foreground" Value="{StaticResource B.TextPrimary}"/>
        <Setter Property="Background" Value="{StaticResource B.Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource B.Border}"/>
        <Setter Property="FontFamily" Value="{StaticResource F.App}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="Padding" Value="7,4"/>
        <Setter Property="Height" Value="32"/>
    </Style>

    <!-- ════════ CheckBox（ダイアログ用・標準寄せ）════════ -->
    <Style TargetType="{x:Type CheckBox}">
        <Setter Property="Foreground" Value="{StaticResource B.TextPrimary}"/>
        <Setter Property="FontFamily" Value="{StaticResource F.App}"/>
        <Setter Property="FontSize" Value="13"/>
        <Setter Property="VerticalContentAlignment" Value="Center"/>
    </Style>

    <!-- ════════ Label / GroupBox / TextBlock 既定 ════════ -->
    <Style TargetType="{x:Type TextBlock}">
        <Setter Property="Foreground" Value="{StaticResource B.TextPrimary}"/>
        <Setter Property="FontFamily" Value="{StaticResource F.App}"/>
    </Style>

    <Style TargetType="{x:Type GroupBox}">
        <Setter Property="Foreground" Value="{StaticResource B.TextSecondary}"/>
        <Setter Property="BorderBrush" Value="{StaticResource B.Border}"/>
        <Setter Property="FontFamily" Value="{StaticResource F.App}"/>
        <Setter Property="FontSize" Value="12"/>
    </Style>

    <!-- ════════ ListBox / ListBoxItem ════════ -->
    <Style TargetType="{x:Type ListBox}">
        <Setter Property="Background" Value="{StaticResource B.Surface}"/>
        <Setter Property="BorderBrush" Value="{StaticResource B.Border}"/>
        <Setter Property="BorderThickness" Value="0"/>
        <Setter Property="FontFamily" Value="{StaticResource F.App}"/>
        <Setter Property="ScrollViewer.HorizontalScrollBarVisibility" Value="Disabled"/>
    </Style>

    <Style TargetType="{x:Type ListBoxItem}">
        <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
        <Setter Property="Padding" Value="0"/>
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Cursor" Value="Hand"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ListBoxItem}">
                    <Border x:Name="bd" Background="{TemplateBinding Background}"
                            BorderBrush="{StaticResource B.BorderLight}" BorderThickness="0,0,0,1">
                        <ContentPresenter VerticalAlignment="Center"/>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.HoverBg}"/>
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="bd" Property="Background" Value="{StaticResource B.Accent}"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- ════════ 細いスクロールバー ════════ -->
    <Style x:Key="ThinScrollThumb" TargetType="{x:Type Thumb}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type Thumb}">
                    <Border Background="{StaticResource B.ScrollThumb}" CornerRadius="4" Margin="2"/>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <Style TargetType="{x:Type ScrollBar}">
        <Setter Property="Background" Value="Transparent"/>
        <Setter Property="Width" Value="8"/>
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="{x:Type ScrollBar}">
                    <Grid Background="Transparent">
                        <Track x:Name="PART_Track" IsDirectionReversed="True">
                            <Track.Thumb>
                                <Thumb Style="{StaticResource ThinScrollThumb}"/>
                            </Track.Thumb>
                            <Track.IncreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageDownCommand" Opacity="0" Focusable="False"/>
                            </Track.IncreaseRepeatButton>
                            <Track.DecreaseRepeatButton>
                                <RepeatButton Command="ScrollBar.PageUpCommand" Opacity="0" Focusable="False"/>
                            </Track.DecreaseRepeatButton>
                        </Track>
                    </Grid>
                    <ControlTemplate.Triggers>
                        <Trigger Property="Orientation" Value="Horizontal">
                            <Setter Property="Width" Value="Auto"/>
                            <Setter Property="Height" Value="8"/>
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

</ResourceDictionary>
