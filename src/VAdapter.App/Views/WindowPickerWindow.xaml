<Window x:Class="VAdapter.App.Views.WindowPickerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        Title="実行中ウィンドウの選択" Height="460" Width="640"
        WindowStartupLocation="CenterOwner">
    <DockPanel Margin="10">
        <TextBlock DockPanel.Dock="Top" Margin="0,0,0,8"
                   Text="対象アプリのウィンドウを選択してください。" />
        <StackPanel DockPanel.Dock="Bottom" Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,8,0,0">
            <Button Content="更新" Width="80" Margin="0,0,8,0" Click="OnRefresh"/>
            <Button Content="選択" Width="80" Margin="0,0,8,0" IsDefault="True" Click="OnSelect"/>
            <Button Content="キャンセル" Width="90" IsCancel="True"/>
        </StackPanel>
        <ListView x:Name="WindowList" MouseDoubleClick="OnSelect">
            <ListView.View>
                <GridView>
                    <GridViewColumn Header="タイトル" Width="340" DisplayMemberBinding="{Binding Title}"/>
                    <GridViewColumn Header="プロセス" Width="160" DisplayMemberBinding="{Binding ProcessName}"/>
                    <GridViewColumn Header="クラス" Width="100" DisplayMemberBinding="{Binding ClassName}"/>
                </GridView>
            </ListView.View>
        </ListView>
    </DockPanel>
</Window>
